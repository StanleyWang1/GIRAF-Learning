# ROS master running on the robot NUC.
ROS_MASTER_URI=http://anymal-d109-lpc:11311

# Control-PC address reachable from the robot NUC. Do not use loopback, a
# Docker bridge address, or the OptiTrack-only interface address.
ROS_IP=192.168.0.231

# Prefer a stable /dev/input/by-id path for the physical keyboard.
DEADMAN_KEYBOARD_DEVICE=/dev/input/by-id/usb-REPLACE_WITH_KEYBOARD-event-kbd

OPTITRACK_SERVER_IP=172.24.68.77
# Leave empty to select the local address using the route to Motive.
OPTITRACK_CLIENT_IP=
OPTITRACK_RIGID_ID=33

